# Copy to .env and adjust. All values have sensible defaults.

# HTTP
PORT=3000
HOST=0.0.0.0

# Redis
REDIS_URL=redis://localhost:6379

# Rate limiter behaviour
# When Redis is unreachable: "open" (allow) or "closed" (block)
RL_FAIL_MODE=open
# Default rule applied when no route-specific rule matches
RL_DEFAULT_LIMIT=100
RL_DEFAULT_WINDOW_MS=60000
RL_DEFAULT_BURST=20

# Adaptive worker
RL_STREAM_KEY=rl:events
RL_STREAM_MAXLEN=100000
RL_ADAPTIVE_ENABLED=true

# Logging
LOG_LEVEL=info
