{
  "name": "adaptive-rate-limiter",
  "version": "0.1.0",
  "description": "Distributed Redis-backed rate limiter with an async adaptive (anomaly-aware) layer",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node src/adaptive/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "bench": "node bench/run.js"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "pino": "^9.3.2",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "autocannon": "^7.15.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "testcontainers": "^10.11.0",
    "vitest": "^2.0.5"
  },
  "license": "MIT"
}
